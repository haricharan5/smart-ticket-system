# ── Azure SQL ────────────────────────────────────────────────────────────────
AZURE_SQL_SERVER=smartticket-sql.database.windows.net
AZURE_SQL_DATABASE=ticketdb
AZURE_SQL_USERNAME=sqladmin
AZURE_SQL_PASSWORD=Ticket@2024Secure!
SQL_ENCRYPT=yes
SQL_TRUST_CERT=no

# Local Docker dev overrides (uncomment for docker-compose):
# AZURE_SQL_SERVER=db
# AZURE_SQL_USERNAME=sa
# AZURE_SQL_PASSWORD=YourStrong!Passw0rd
# SQL_TRUST_CERT=yes

# ── Azure Language Service ────────────────────────────────────────────────────
AZURE_LANGUAGE_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=YOUR_LANGUAGE_KEY_HERE

# ── Local LLM (Ollama on VM2) ─────────────────────────────────────────────────
# Ollama exposes an OpenAI-compatible API on port 11434.
# In production: use VM2's private IP (stays within the Azure VNet, no egress).
# In local Docker dev: set to http://host.docker.internal:11434/v1
#
# Supported models (pull with: ollama pull <model>):
#   phi3:mini        — 3.8B params, ~2.3 GB RAM, fastest, best for classification
#   llama3.2:3b      — 3.2B params, ~2.0 GB RAM, good general quality
#   mistral:7b-q4    — 7B params, ~4.5 GB RAM, highest quality (needs B4ms VM)
LLM_BASE_URL=http://YOUR_VM2_PRIVATE_IP:11434/v1
LLM_MODEL=phi3:mini

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://YOUR_VM3_IP

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/var/log/smartticket/app.log

# ── Azure Application Insights (optional) ─────────────────────────────────────
# Get from Azure Portal → Application Insights → Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
